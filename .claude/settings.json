{
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.development)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(git checkout -- *)",
      "Bash(git reset --hard *)",
      "Bash(git add -f *)",
      "Bash(git add --force *)"
    ],
    "allow": [
      "Read",
      "Read(./.env.example)",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(python manage.py test*)",
      "Bash(python -Wa manage.py test*)"
    ]
  }
}
